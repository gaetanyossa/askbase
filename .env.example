# ==============================================
# AskBase Configuration
# Copy this file to .env and fill in your values
# ==============================================

# -- LLM Provider --
# Options: openai | anthropic | gemini
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini  # auto-detected if empty

# -- Database Type --
# Options: bigquery | mysql | postgresql | sqlite
DB_TYPE=sqlite

# -- SQLite (simplest setup) --
SQLITE_PATH=demo.db

# -- PostgreSQL --
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=my_database
# DB_USER=postgres
# DB_PASSWORD=

# -- MySQL --
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=my_database
# DB_USER=root
# DB_PASSWORD=

# -- BigQuery --
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service_account.json
# BIGQUERY_PROJECT=your-project-id
# BIGQUERY_DATASET=your_dataset

# -- General --
MAX_ROWS=100
# PORT=8080
